# CraftAgent Pro - Complete Environment Configuration

# Anthropic API Configuration (used by backend)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend Configuration  
REACT_APP_BACKEND_URL=http://localhost:8000

# Backend Configuration (only used by backend)
BACKEND_PORT=8000

# Optional: Claude model selection (default: claude-3-sonnet-20240229)
# CLAUDE_MODEL=claude-3-sonnet-20240229

# Demo Mode (set to false to use live API)
# REACT_APP_DEMO_MODE=true